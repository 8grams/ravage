{
  "dependencies": {
    "tailwindcss": "4.0.9",
    "@tailwindcss/cli": "4.0.9",
    "daisyui": "5.0.0"
  },
  "scripts": {
    "dev": "pnpm dlx @tailwindcss/cli -i templates/styles/app.css -o static/app.css --watch",
